<Window x:Class="ShowDriveInfo.ScanProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сканирование"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="{Binding Status}" Margin="0,0,0,4" />
    <TextBlock Grid.Row="1" Text="{Binding ProgressPath}" Foreground="Gray"
               TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
    <ProgressBar Grid.Row="2" Height="18" IsIndeterminate="True" />
    <Grid Grid.Row="3" Margin="0,10,0,0">
      <TextBlock VerticalAlignment="Center"
                 Text="{Binding ProgressCount, StringFormat=Обработано: {0}}" />
      <Button HorizontalAlignment="Right" Padding="14,3" Content="Отмена"
              Command="{Binding CancelCommand}" />
    </Grid>
  </Grid>
</Window>
